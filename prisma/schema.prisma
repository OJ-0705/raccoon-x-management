generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id           String    @id @default(cuid())
  content      String
  postType     String
  formatType   String    @default("テキスト")
  status       String    @default("下書き")
  scheduledAt  DateTime?
  postedAt     DateTime?
  xPostId      String?
  impressions  Int       @default(0)
  likes        Int       @default(0)
  retweets     Int       @default(0)
  replies      Int       @default(0)
  bookmarks    Int       @default(0)
  imageUrls        String?
  hashtags         String?
  threadPosts      String?
  parentPostId     String?
  platform         String    @default("x")
  threadsPostId    String?
  threadsImp       Int       @default(0)
  threadsLikes     Int       @default(0)
  threadsReplies   Int       @default(0)
  threadsReposts   Int       @default(0)
  abGroupId        String?
  abVariant        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Competitor {
  id          String   @id @default(cuid())
  username    String   @unique
  displayName String?
  createdAt   DateTime @default(now())
}

model Keyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  createdAt DateTime @default(now())
}

model Analytics {
  id               String   @id @default(cuid())
  date             DateTime @unique
  followers        Int?
  totalImpressions Int?
  totalEngagements Int?
  createdAt        DateTime @default(now())
}

model PostTemplate {
  id              String   @id @default(cuid())
  name            String
  postType        String
  templateContent String
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
